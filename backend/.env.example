# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>

# JWT Configuration
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d

# Groq API for Agentic Chatbot (tool-calling agent — uses LLaMA-3.3-70b)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Gemini API (alternative — currently unused by chatbot)
# GEMINI_API_KEY=your_gemini_api_key_here

# # Cloudinary Configuration (Optional - for cloud image storage)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL
FRONTEND_URL=http://localhost:3000

# College Info
COLLEGE_NAME=Samarth Rural Educational Institute - SAMARTH COLLEGE OF ENGINEERING & MANAGEMENT, BELHE
